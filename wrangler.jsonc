{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "qfund-website",
  "main": "./dist/server/index.js",
  "compatibility_date": "2026-05-15",
  "compatibility_flags": ["nodejs_compat"],
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": ["**/*.js", "**/*.mjs"]
    }
  ],
  "assets": {
    "directory": "./dist/client"
  },
  "observability": {
    "enabled": true
  }
}
